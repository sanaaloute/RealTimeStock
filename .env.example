# ---------------------------------------------------------------------------
# Required: market data + LLM brain
# ---------------------------------------------------------------------------
# Tavily API key (scrapers). Get one at https://tavily.com
TAVILY_API_KEY=

# LLM provider: ollama | groq | openrouter
LLM_PROVIDER=ollama
# Optional overrides for the selected provider
OLLAMA_MODEL=qwen3:8b
LLM_TEMPERATURE=0.5

# --- Ollama (when LLM_PROVIDER=ollama) ---
# OLLAMA_MODEL=llama3.2:3b
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_KEEP_ALIVE=2m

# Ollama Cloud instead of a local GPU (https://ollama.com/settings/keys):
# OLLAMA_CLOUD=true
# OLLAMA_API_KEY=

# --- Groq (when LLM_PROVIDER=groq). https://console.groq.com/keys ---
# GROQ_API_KEY=
# GROQ_MODEL=openai/gpt-oss-120b

# --- OpenRouter (when LLM_PROVIDER=openrouter). https://openrouter.ai/settings/keys ---
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free


# ---------------------------------------------------------------------------
# Required: Telegram bot
# ---------------------------------------------------------------------------
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Shared secret the bot sends as X-API-Key to the Chat API.
# REQUIRED in production — if empty, the API accepts unauthenticated requests.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=

# Chat API URL the bot calls. Default http://localhost:8000
# (docker compose sets this to http://api:8000 automatically)
# BRVM_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Production database (PostgreSQL)
# ---------------------------------------------------------------------------
# Password for the bundled PostgreSQL service (docker compose only).
POSTGRES_PASSWORD=
# Full connection string. docker compose sets this automatically from
# POSTGRES_PASSWORD. Leave EMPTY for local SQLite files in app/data/ (dev).
# DATABASE_URL=postgresql://brvm:<password>@localhost:5432/brvm

# ---------------------------------------------------------------------------
# Optional: WhatsApp Business Cloud API channel
# All three required to enable. Webhook: GET/POST /whatsapp/webhook (public HTTPS).
# ---------------------------------------------------------------------------
# WHATSAPP_VERIFY_TOKEN=choose-a-random-string
# WHATSAPP_ACCESS_TOKEN=EAAG...
# WHATSAPP_PHONE_NUMBER_ID=123456789012345

# ---------------------------------------------------------------------------
# Optional tuning (defaults shown — uncomment to change)
# ---------------------------------------------------------------------------
# SCRAPER_SLEEP_SECONDS=2          # pause between scraper requests
# BRVM_VERIFY_SSL=true             # set false only for certificate-chain issues
# PALMARES_CACHE_TTL_SECONDS=300   # market data scrape interval (stale cache served on failure)
# MAX_CONCURRENT_AGENTS=4          # concurrent agent runs on the Chat API
# AGENT_QUEUE_TIMEOUT=60           # seconds a request waits for a free agent slot
# RATE_LIMIT_PER_MINUTE=30         # per-user /chat rate limit (0 disables)
# DAILY_FREE_QUOTA=30              # free requests per user per day (0 = unlimited; failures refunded)
# QUOTA_EXEMPT_IDS=123456789       # comma-separated ids with no quota (Telegram id or wa:225...)
# TIMESERIES_SYMBOLS=NTLC,SLBC     # default: all symbols from BRVM_Companies.xlsx
# RECURSION_LIMIT=100              # max agent steps before a partial answer
# SGI_REFRESH_DAYS=7               # docker: refresh broker list when older than N days
