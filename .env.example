# Get your API key at https://tavily.com
TAVILY_API_KEY=tvly-YOUR_API_KEY

# Sleep in seconds between each request (be respectful to targets)
SCRAPER_SLEEP_SECONDS=2

# Chat API URL (bot calls this). Default http://localhost:8000
# - Same machine: http://localhost:8000
# - Bot in Docker, API on host: http://host.docker.internal:8000 (Windows/Mac) or http://172.17.0.1:8000 (Linux)
# - Bot on remote server: API must run on same server or be reachable; use that URL
# BRVM_API_URL=http://localhost:8000

# Telegram bot (optional; for run_telegram_bot.py)
# Create bot with @BotFather, then set:
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Comma-separated Telegram user IDs (get yours from @userinfobot)
ALLOWED_TELEGRAM_IDS=123456789

# Market data cache: palmarès page is scraped at most once per TTL (default 300 = 5 min).
# If a refresh fails, the last good snapshot is served so the bot keeps answering.
# PALMARES_CACHE_TTL_SECONDS=300

# Chat API: max concurrent agent runs; extra requests wait up to AGENT_QUEUE_TIMEOUT
# seconds then get a friendly "busy" reply. Defaults: 4 concurrent, 60s wait.
# MAX_CONCURRENT_AGENTS=4
# AGENT_QUEUE_TIMEOUT=60

# Chat API auth: the bot must send this secret as the X-API-Key header.
# REQUIRED for production — if empty, the API accepts unauthenticated requests (dev only).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=

# Per-user rate limit on /chat (requests per minute). 0 disables. Default 30.
# RATE_LIMIT_PER_MINUTE=30

# Free daily quota on /chat (requests per user per UTC day). 0 = unlimited. Default 30.
# Failed requests are refunded. QUOTA_EXEMPT_IDS: comma-separated user ids with no limit.
# DAILY_FREE_QUOTA=30
# QUOTA_EXEMPT_IDS=123456789

# WhatsApp Business Cloud API channel (all three required to enable). The webhook is
# served by the Chat API at GET/POST /whatsapp/webhook and must be public HTTPS.
# WHATSAPP_VERIFY_TOKEN=choose-a-random-string
# WHATSAPP_ACCESS_TOKEN=EAAG...
# WHATSAPP_PHONE_NUMBER_ID=123456789012345

# Ollama model for the agent (CLI and Telegram)
OLLAMA_MODEL=glm-5:cloud
# How long to keep model in GPU after last request. Use "0" to unload immediately and free GPU.
# Examples: "2m" (default), "5m", "0" (unload right away)
# OLLAMA_KEEP_ALIVE=2m
# Ollama Cloud: use https://ollama.com directly (no local GPU). Get API key at https://ollama.com/settings/keys
# OLLAMA_CLOUD=true
# OLLAMA_API_KEY=your_api_key
# Ollama URL (optional). Set only if Ollama is not on default localhost:11434:
# - Bot on HOST, Ollama on HOST: leave unset or OLLAMA_BASE_URL=http://127.0.0.1:11434
# - Bot in DOCKER, Ollama on HOST: OLLAMA_BASE_URL=http://host.docker.internal:11434  (Windows/Mac) or http://172.17.0.1:11434 (Linux)
# - Bot in DOCKER, Ollama in DOCKER (compose ollama service): OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_BASE_URL=http://127.0.0.1:11434
