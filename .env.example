# Copy this file to .env and fill in your values.
# NEVER commit .env to version control—it contains secrets. (.env is in .gitignore)
#
# Get your API key at https://tavily.com
TAVILY_API_KEY=tvly-YOUR_API_KEY

# Sleep in seconds between each request (be respectful to targets)
SCRAPER_SLEEP_SECONDS=2

# Chat API URL (bot calls this). Default http://localhost:8000
# - Same machine: http://localhost:8000
# - Bot in Docker, API on host: http://host.docker.internal:8000 (Windows/Mac) or http://172.17.0.1:8000 (Linux)
# - Bot on remote server: API must run on same server or be reachable; use that URL
# BRVM_API_URL=http://localhost:8000

# Telegram bot (optional; for run_telegram_bot.py)
# Create bot with @BotFather, then set:
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Comma-separated Telegram user IDs (get yours from @userinfobot)
ALLOWED_TELEGRAM_IDS=123456789

# LLM provider: ollama | groq | openrouter
LLM_PROVIDER=ollama
# Optional: override model for current provider
# LLM_MODEL=llama3.2:3b
# LLM temperature (0=deterministic, 0.5=balanced, 1=creative)
# LLM_TEMPERATURE=0.5

# Ollama (when LLM_PROVIDER=ollama)
OLLAMA_MODEL=llama3.2:3b
# How long to keep model in GPU after last request. Use "0" to unload immediately and free GPU.
# Examples: "2m" (default), "5m", "0" (unload right away)
# OLLAMA_KEEP_ALIVE=2m
# Ollama Cloud: use https://ollama.com directly (no local GPU). Get API key at https://ollama.com/settings/keys
# OLLAMA_CLOUD=true
# OLLAMA_API_KEY=your_api_key
# Ollama URL (optional). Set only if Ollama is not on default localhost:11434:
# - Bot on HOST, Ollama on HOST: leave unset or OLLAMA_BASE_URL=http://127.0.0.1:11434
# - Bot in DOCKER, Ollama on HOST: OLLAMA_BASE_URL=http://host.docker.internal:11434  (Windows/Mac) or http://172.17.0.1:11434 (Linux)
# - Bot in DOCKER, Ollama in DOCKER (compose ollama service): OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# Graph: max steps (default 50). Increase if complex queries hit limit.
# RECURSION_LIMIT=100

# Groq (when LLM_PROVIDER=groq). Get API key at https://console.groq.com/keys
# GROQ_API_KEY=your_groq_api_key
# GROQ_MODEL=llama-3.1-8b-instant

# OpenRouter (when LLM_PROVIDER=openrouter). Get API key at https://openrouter.ai/settings/keys
# OPENROUTER_API_KEY=your_openrouter_api_key
# OPENROUTER_MODEL=anthropic/claude-3-haiku
# Optional: for rankings on openrouter.ai
# OPENROUTER_SITE_URL=https://your-site.com
# OPENROUTER_SITE_NAME=BRVM Stock Bot
