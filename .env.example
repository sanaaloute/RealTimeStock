# Copy this file to .env and fill in your values.
# NEVER commit .env to version control—it contains secrets. (.env is in .gitignore)

# ---------------------------------------------------------------------------
# Tavily (scrapers)
# Get your API key at https://tavily.com
# ---------------------------------------------------------------------------
TAVILY_API_KEY=tvly-YOUR_API_KEY

# Sleep in seconds between each request (be respectful to targets)
SCRAPER_SLEEP_SECONDS=4

# Set to 0 or false to skip SSL verification for brvm.org (if you get CERTIFICATE_VERIFY_FAILED)
# BRVM_VERIFY_SSL=false

# ---------------------------------------------------------------------------
# Chat API & Telegram bot
# ---------------------------------------------------------------------------
# Chat API URL (bot calls this). Default http://localhost:8000
# BRVM_API_URL=http://localhost:8000

# Telegram bot: create with @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Optional: not used for access; bot is open to all. Chat/memory are keyed by user ID.
# ALLOWED_TELEGRAM_IDS=123456789

# Chat API auth: the bot must send this secret as the X-API-Key header.
# REQUIRED for production — if empty, the API accepts unauthenticated requests (dev only).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=

# Per-user rate limit on /chat (requests per minute). 0 disables. Default 30.
# RATE_LIMIT_PER_MINUTE=30

# Free daily quota on /chat (requests per user per UTC day). 0 = unlimited. Default 30.
# Failed requests are refunded. QUOTA_EXEMPT_IDS: comma-separated user ids with no limit
# (raw Telegram ids or channel keys like wa:22507000000).
# DAILY_FREE_QUOTA=30
# QUOTA_EXEMPT_IDS=123456789

# Chat API concurrency: max concurrent agent runs; extra requests wait up to
# AGENT_QUEUE_TIMEOUT seconds then get a friendly "busy" reply. Defaults: 4, 60s.
# MAX_CONCURRENT_AGENTS=4
# AGENT_QUEUE_TIMEOUT=60

# Market data cache: palmarès page is scraped at most once per TTL (default 300 = 5 min).
# If a refresh fails, the last good snapshot is served so the bot keeps answering.
# PALMARES_CACHE_TTL_SECONDS=300

# WhatsApp Business Cloud API channel (all three required to enable). The webhook is
# served by the Chat API at GET/POST /whatsapp/webhook and must be public HTTPS.
# WHATSAPP_VERIFY_TOKEN=choose-a-random-string
# WHATSAPP_ACCESS_TOKEN=EAAG...
# WHATSAPP_PHONE_NUMBER_ID=123456789012345

# ---------------------------------------------------------------------------
# Daily timeseries update
# If unset or empty: all symbols from app/data/BRVM_Companies.xlsx are used.
# ---------------------------------------------------------------------------
# TIMESERIES_SYMBOLS=NTLC,SLBC,SNTS

# ---------------------------------------------------------------------------
# LLM provider: ollama | groq | openrouter
# ---------------------------------------------------------------------------
LLM_PROVIDER=ollama
# Optional: override model for current provider
# LLM_MODEL=llama3.2:3b
# LLM temperature (0=deterministic, 0.5=balanced, 1=creative)
# LLM_TEMPERATURE=0.5

# ---------------------------------------------------------------------------
# Ollama (when LLM_PROVIDER=ollama)
# ---------------------------------------------------------------------------
# OLLAMA_MODEL=llama3.2:3b
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_KEEP_ALIVE=2m
# Ollama Cloud (no local GPU): https://ollama.com/settings/keys
# OLLAMA_CLOUD=true
# OLLAMA_API_KEY=your_ollama_cloud_key

# ---------------------------------------------------------------------------
# Groq (when LLM_PROVIDER=groq). https://console.groq.com/keys
# ---------------------------------------------------------------------------
# GROQ_API_KEY=your_groq_api_key
# GROQ_MODEL=llama-3.1-8b-instant

# ---------------------------------------------------------------------------
# OpenRouter (when LLM_PROVIDER=openrouter). https://openrouter.ai/settings/keys
# ---------------------------------------------------------------------------
# OPENROUTER_API_KEY=sk-or-v1-your_key
# OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free
# Optional: for rankings on openrouter.ai
# OPENROUTER_SITE_URL=https://your-site.com
# OPENROUTER_SITE_NAME=BRVM Stock Bot

# ---------------------------------------------------------------------------
# Graph: max steps before stopping (prevents endless loops)
# ---------------------------------------------------------------------------
# RECURSION_LIMIT=100

# ---------------------------------------------------------------------------
# Optional: system proxy bypass (e.g. for localhost API calls)
# ---------------------------------------------------------------------------
# NO_PROXY=localhost,127.0.0.1
