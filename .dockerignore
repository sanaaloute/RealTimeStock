# Git and IDE
.git
.gitignore
.cursor
.vscode
*.md
!data/*.txt

# Env (use docker-compose env_file or -e)
.env
.env.*
!.env.example

# Python
__pycache__
*.py[cod]
*$py.class
*.so
.venv
venv
env

# Data we don't need in image (series CSVs are created at runtime / volume)
data/series/
app/data/series/

# Never bake local user databases / caches into the image (runtime volume owns them)
app/data/*.db
app/data/*.db-*
app/data/palmares_cache.json
app/data/sgi_brvm.json

# Tests and dev
tests
pytest.ini
.coverage
htmlcov
*.egg-info
.eggs

# Misc
*.log
.DS_Store
mcps
